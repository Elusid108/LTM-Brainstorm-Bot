{
  "name": "ltm-brainstorm",
  "version": "1.2.6",
  "description": "Local-first JARVIS-style AI brainstorming assistant with Long-Term Memory",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "node -e \"process.exit(0)\"",
    "dist": "npm run build && electron-builder --win"
  },
  "keywords": [
    "electron",
    "llm",
    "rag",
    "brainstorm",
    "ltm"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "sqlite-vec": "^0.1.7-alpha.2",
    "sqlite3": "^5.1.7",
    "systeminformation": "^5.31.1"
  },
  "build": {
    "appId": "com.strata.desktop",
    "productName": "Strata",
    "asarUnpack": [
      "**/*.gguf",
      "models/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
